NODE_ENV=development

# Resend — get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Sender address (must be verified in Resend)
EMAIL_FROM="The Shop <orders@yourdomain.com>"

# Fixed recipient for order notifications (v1)
EMAIL_RECIPIENT=orders@yourcompany.com

# Shared secret — generate with: openssl rand -hex 32
ORDER_API_KEY=

# React app origin (used for CORS)
ALLOWED_ORIGIN=http://localhost:5173
