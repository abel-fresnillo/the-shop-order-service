NODE_ENV=development

# Resend — get your API key at https://resend.com/api-keys
RESEND_API_KEY=re_...

# Sender address (must be verified in Resend)
EMAIL_FROM="The Shop <orders@yourdomain.com>"

# Fixed recipient for order notifications (v1)
EMAIL_RECIPIENT=orders@yourcompany.com

# Shared secret — generate with: openssl rand -hex 32
ORDER_API_KEY=

# CORS — comma-separated list of exact origins to allow (no trailing slash)
ALLOWED_ORIGINS=http://localhost:5173,https://your-frontend.vercel.app

# Optional: regex pattern to also allow Vercel preview deployments
# Example: https://the-shop-storefront-.*\.vercel\.app
ALLOWED_ORIGIN_PATTERN=

# Neon Postgres connection string — find it in your Neon project dashboard
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# OpenTelemetry / Grafana Cloud
# OTLP endpoint — find it in Grafana Cloud > Stack > OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp-gateway-prod-us-east-3.grafana.net/otlp
# Grafana Cloud stack numeric ID (Stack > Details)
GRAFANA_INSTANCE_ID=
# API token with MetricsPublisher + LogsPublisher + TracesPublisher scopes
GRAFANA_API_TOKEN=
# Service name shown in Grafana dashboards
OTEL_SERVICE_NAME=the-shop-order-service
# Loki endpoint — find it in Grafana Cloud > Stack > Loki > Details
LOKI_HOST=https://logs-prod-042.grafana.net
# Loki numeric user ID (different from GRAFANA_INSTANCE_ID)
LOKI_USER=
# Log verbosity (default: info)
LOG_LEVEL=info
